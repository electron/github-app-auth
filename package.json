{
  "name": "@electron/github-app-auth",
  "version": "0.0.0-development",
  "description": "Gets an auth token for a repo via a GitHub app installation",
  "type": "module",
  "exports": "./dist/index.js",
  "author": "Samuel Attard <sam@electronjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/electron/github-app-auth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron/github-app-auth.git"
  },
  "bugs": {
    "url": "https://github.com/electron/github-app-auth/issues"
  },
  "publishConfig": {
    "provenance": true
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "github-app-auth-build": "dist/bin.js"
  },
  "scripts": {
    "lint": "oxfmt --check . && oxlint",
    "lint:fix": "oxfmt --write . && oxlint --fix",
    "prepare": "husky",
    "prepublishOnly": "tsc",
    "test": "yarn lint && yarn tsc"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.json": [
      "oxfmt --write"
    ]
  },
  "devDependencies": {
    "@octokit/types": "^14.1.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typedoc": "~0.28.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.1.0",
    "@octokit/rest": "^22.0.0"
  },
  "files": [
    "dist"
  ],
  "packageManager": "yarn@4.9.4"
}
